# Required: OpenRouter (https://openrouter.ai) powers the agent's model calls.
OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=

# Required for Telegram mode only.
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_ID=

# Optional: enables web_search / web_crawl / fetch_url tools (https://firecrawl.dev).
FIRECRAWL_API_KEY=

# Optional: extra directories to search for agent skills (colon-separated).
SKILLS_DIRS=
